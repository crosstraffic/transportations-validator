{
  "source_doc": {
    "title": "Lane Detection Validation Rules",
    "abbreviation": "LANE-VAL",
    "edition": "1.0",
    "publisher": "Transportation Validator",
    "publication_year": 2025,
    "jurisdiction": "federal",
    "priority": 100
  },
  "rules": [
    {
      "parameter_rust_field": "lane_width",
      "facility_type": "LaneGeometry",
      "name": "Lane Width Physical Limits",
      "rule_type": "range",
      "severity": "error",
      "min_value": 6.0,
      "max_value": 20.0,
      "description": "Detected lane width must be physically plausible",
      "error_message": "Lane width is physically implausible (must be 6-20 ft)",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "lane_width",
      "facility_type": "LaneGeometry",
      "name": "Travel Lane Width AASHTO Compliance",
      "rule_type": "range",
      "severity": "warning",
      "min_value": 10.0,
      "max_value": 12.0,
      "description": "Travel lane width per AASHTO Green Book guidelines",
      "error_message": "Lane width outside AASHTO typical range (10-12 ft)",
      "source_ref": {"chapter": "4", "section": "4.7"}
    },
    {
      "parameter_rust_field": "lane_width",
      "facility_type": "LaneGeometry",
      "name": "Adjacent Lane Width Consistency",
      "rule_type": "formula",
      "severity": "warning",
      "formula": "abs(lane_width - adjacent_lane_width) <= 1.0",
      "description": "Adjacent lanes should have similar widths",
      "error_message": "Lane width differs from adjacent lane by more than 1 ft",
      "source_ref": {"chapter": "Quality", "section": "Consistency"}
    },
    {
      "parameter_rust_field": "lane_length",
      "facility_type": "LaneGeometry",
      "name": "Lane Length Physical Limits",
      "rule_type": "range",
      "severity": "error",
      "min_value": 10.0,
      "max_value": 10000.0,
      "description": "Lane segment length must be reasonable",
      "error_message": "Lane segment length is implausible",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "lane_count",
      "facility_type": "LaneGeometry",
      "name": "Lane Count Physical Limits",
      "rule_type": "range",
      "severity": "error",
      "min_value": 1,
      "max_value": 10,
      "description": "Lane count in one direction",
      "error_message": "Lane count is implausible (must be 1-10)",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "lane_type",
      "facility_type": "LaneGeometry",
      "name": "Valid Lane Type",
      "rule_type": "enum",
      "severity": "error",
      "allowed_values": "travel,turn_left,turn_right,hov,parking,bike,bus,shoulder",
      "description": "Lane type must be a recognized category",
      "error_message": "Invalid lane type",
      "source_ref": {"chapter": "Classification", "section": "Types"}
    },
    {
      "parameter_rust_field": "centerline_offset",
      "facility_type": "LaneGeometry",
      "name": "Centerline Offset Tolerance",
      "rule_type": "range",
      "severity": "warning",
      "min_value": -2.0,
      "max_value": 2.0,
      "description": "Centerline should be within 2 ft of expected position",
      "error_message": "Centerline offset exceeds 2 ft tolerance",
      "source_ref": {"chapter": "Quality", "section": "Position"}
    },
    {
      "parameter_rust_field": "curvature",
      "facility_type": "LaneGeometry",
      "name": "Curvature Physical Limits",
      "rule_type": "range",
      "severity": "error",
      "min_value": 0.0,
      "max_value": 0.02,
      "description": "Curvature must be physically reasonable (radius > 50 ft)",
      "error_message": "Curvature implies radius < 50 ft, which is implausible",
      "source_ref": {"chapter": "Physical", "section": "Geometry"}
    },
    {
      "parameter_rust_field": "curvature",
      "facility_type": "LaneGeometry",
      "name": "Curvature AASHTO Minimum Radius",
      "rule_type": "max",
      "severity": "warning",
      "max_value": 0.0037,
      "description": "Curvature implies radius should be > 270 ft for 30 mph",
      "error_message": "Tight curve detected - verify design speed compatibility",
      "source_ref": {"chapter": "3", "section": "3.3.3"}
    },
    {
      "parameter_rust_field": "lane_grade",
      "facility_type": "LaneGeometry",
      "name": "Lane Grade Physical Limits",
      "rule_type": "range",
      "severity": "error",
      "min_value": -20.0,
      "max_value": 20.0,
      "description": "Grade must be physically reasonable",
      "error_message": "Grade exceeds physical limits",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "lane_grade",
      "facility_type": "LaneGeometry",
      "name": "Lane Grade AASHTO Limits",
      "rule_type": "range",
      "severity": "warning",
      "min_value": -8.0,
      "max_value": 8.0,
      "description": "Grade should typically be within AASHTO limits",
      "error_message": "Grade exceeds typical AASHTO maximum (8%)",
      "source_ref": {"chapter": "7", "section": "7.4"}
    },
    {
      "parameter_rust_field": "cross_slope",
      "facility_type": "LaneGeometry",
      "name": "Cross Slope Physical Limits",
      "rule_type": "range",
      "severity": "error",
      "min_value": -12.0,
      "max_value": 12.0,
      "description": "Cross slope must be physically reasonable",
      "error_message": "Cross slope exceeds physical limits",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "cross_slope",
      "facility_type": "LaneGeometry",
      "name": "Cross Slope Normal Range",
      "rule_type": "range",
      "severity": "warning",
      "min_value": -8.0,
      "max_value": 8.0,
      "description": "Cross slope typically within superelevation limits",
      "error_message": "Cross slope exceeds typical superelevation (8%)",
      "source_ref": {"chapter": "3", "section": "3.3.4"}
    },
    {
      "parameter_rust_field": "confidence",
      "facility_type": "LaneGeometry",
      "name": "Detection Confidence Minimum",
      "rule_type": "min",
      "severity": "warning",
      "min_value": 0.7,
      "description": "Minimum confidence for reliable detection",
      "error_message": "Low detection confidence - manual review recommended",
      "source_ref": {"chapter": "Quality", "section": "Confidence"}
    },
    {
      "parameter_rust_field": "confidence",
      "facility_type": "LaneGeometry",
      "name": "Detection Confidence Valid Range",
      "rule_type": "range",
      "severity": "error",
      "min_value": 0.0,
      "max_value": 1.0,
      "description": "Confidence must be between 0 and 1",
      "error_message": "Invalid confidence score (must be 0-1)",
      "source_ref": {"chapter": "Quality", "section": "Confidence"}
    },
    {
      "parameter_rust_field": "width_variance",
      "facility_type": "LaneGeometry",
      "name": "Width Variance Maximum",
      "rule_type": "max",
      "severity": "warning",
      "max_value": 1.0,
      "description": "Width variance should be low for consistent detection",
      "error_message": "High width variance indicates inconsistent detection",
      "source_ref": {"chapter": "Quality", "section": "Consistency"}
    },
    {
      "parameter_rust_field": "continuity_score",
      "facility_type": "LaneGeometry",
      "name": "Boundary Continuity Minimum",
      "rule_type": "min",
      "severity": "warning",
      "min_value": 0.8,
      "description": "Minimum boundary continuity score",
      "error_message": "Low boundary continuity - possible detection gaps",
      "source_ref": {"chapter": "Quality", "section": "Continuity"}
    },
    {
      "parameter_rust_field": "left_line_type",
      "facility_type": "LaneGeometry",
      "name": "Valid Left Line Type",
      "rule_type": "enum",
      "severity": "error",
      "allowed_values": "solid_white,broken_white,solid_yellow,broken_yellow,double_yellow,double_white,none",
      "description": "Left line marking must be a valid MUTCD type",
      "error_message": "Invalid left line marking type",
      "source_ref": {"chapter": "3B", "section": "3B.01"}
    },
    {
      "parameter_rust_field": "right_line_type",
      "facility_type": "LaneGeometry",
      "name": "Valid Right Line Type",
      "rule_type": "enum",
      "severity": "error",
      "allowed_values": "solid_white,broken_white,solid_yellow,broken_yellow,double_yellow,double_white,none",
      "description": "Right line marking must be a valid MUTCD type",
      "error_message": "Invalid right line marking type",
      "source_ref": {"chapter": "3B", "section": "3B.01"}
    },
    {
      "parameter_rust_field": "speed_limit",
      "facility_type": "LaneGeometry",
      "name": "Speed Limit Physical Range",
      "rule_type": "range",
      "severity": "error",
      "min_value": 5,
      "max_value": 85,
      "description": "Speed limit must be within reasonable range",
      "error_message": "Speed limit outside valid range (5-85 mph)",
      "source_ref": {"chapter": "Physical", "section": "Speed"}
    }
  ]
}

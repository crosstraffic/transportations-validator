      "facility_type": "LaneGeometry",
      "name": "Bounding Box Length Car Range",
      "rule_type": "range",
      "severity": "info",
      "min_value": 3.5,
      "max_value": 5.5,
      "description": "Typical car length 3.5-5.5m",

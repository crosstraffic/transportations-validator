      "max_value": 3.0,
      "description": "Typical track width 1.0-3.0m",
      "error_message": "Track width outside typical range",
      "source_ref": {"chapter": "Entities", "section": "Axles"}
    },
    {
      "parameter_rust_field": "max_steer",
      "facility_type": "LaneGeometry",
      "name": "Max Steering Angle Range",
      "rule_type": "range",
      "severity": "warning",
      "min_value": 0.0,
      "max_value": 1.0,
      "description": "Max steering typically 0-1.0 rad (0-57°)",

  "rules": [
    {
      "parameter_rust_field": "vehicle_max_speed",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Max Speed Non-Negative",
      "rule_type": "min",
      "severity": "error",
      "min_value": 0.0,
      "description": "Maximum speed must be non-negative",
      "error_message": "Vehicle max speed cannot be negative",
      "source_ref": {"chapter": "Entities", "section": "Performance"}
    },
    {
      "parameter_rust_field": "vehicle_max_speed",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Max Speed Physical Limit",
      "rule_type": "max",
      "severity": "warning",
      "max_value": 100.0,
      "description": "Max speed typically below 100 m/s (360 km/h)",
      "error_message": "Vehicle max speed exceeds 360 km/h - verify if intentional",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "vehicle_max_accel",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Max Acceleration Non-Negative",
      "rule_type": "min",
      "severity": "error",
      "min_value": 0.0,
      "description": "Maximum acceleration must be non-negative",
      "error_message": "Vehicle max acceleration cannot be negative",
      "source_ref": {"chapter": "Entities", "section": "Performance"}
    },
    {
      "parameter_rust_field": "vehicle_max_accel",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Max Acceleration Physical Limit",
      "rule_type": "max",
      "severity": "warning",
      "max_value": 15.0,
      "description": "Typical vehicle acceleration < 15 m/s²",
      "error_message": "Vehicle acceleration exceeds 15 m/s² - verify if intentional",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "vehicle_max_decel",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Max Deceleration Non-Negative",
      "rule_type": "min",
      "severity": "error",
      "min_value": 0.0,
      "description": "Maximum deceleration must be non-negative",
      "error_message": "Vehicle max deceleration cannot be negative",
      "source_ref": {"chapter": "Entities", "section": "Performance"}
    },
    {
      "parameter_rust_field": "vehicle_max_decel",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Max Deceleration Physical Limit",
      "rule_type": "max",
      "severity": "warning",
      "max_value": 15.0,
      "description": "Typical braking deceleration < 15 m/s²",
      "error_message": "Vehicle deceleration exceeds 15 m/s² - extreme braking",
      "source_ref": {"chapter": "Physical", "section": "Plausibility"}
    },
    {
      "parameter_rust_field": "bbox_length",
      "facility_type": "LaneGeometry",
      "name": "Bounding Box Length Positive",

      "source_ref": {"chapter": "Entities", "section": "Axles"}
    },
    {
      "parameter_rust_field": "vehicle_mass",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Mass Positive",
      "rule_type": "min",
      "severity": "error",
      "min_value": 1.0,
      "description": "Vehicle mass must be positive",
      "error_message": "Vehicle mass must be > 0",
      "source_ref": {"chapter": "Entities", "section": "Vehicle"}
    },
    {
      "parameter_rust_field": "vehicle_mass",
      "facility_type": "LaneGeometry",
      "name": "Vehicle Mass Car Range",
      "rule_type": "range",
      "severity": "info",
      "min_value": 800.0,
      "max_value": 3000.0,
      "description": "Typical car mass 800-3000 kg",
      "error_message": "Vehicle mass outside typical car range",
      "source_ref": {"chapter": "Physical", "section": "Vehicles"}
    },
    {
      "parameter_rust_field": "pedestrian_mass",
      "facility_type": "LaneGeometry",
      "name": "Pedestrian Mass Range",
      "rule_type": "range",
      "severity": "warning",
      "min_value": 10.0,
      "max_value": 200.0,
      "description": "Pedestrian mass typically 10-200 kg",

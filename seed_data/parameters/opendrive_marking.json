      "aliases": ["weight", "line_weight"]
    },
    {
      "name": "Road Mark Color",
      "rust_field": "mark_color",
      "unit": null,
      "data_type": "enum",
      "allowed_values": "standard,blue,green,red,white,yellow,orange",
      "description": "OpenDRIVE road mark color",
      "aliases": ["color", "line_color"]
